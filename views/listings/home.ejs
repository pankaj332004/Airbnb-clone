<% layout("/layouts/boilerplate") %>

  <!-- Hero Section -->
  <div class="hero-section text-center text-white d-flex flex-column align-items-center justify-content-center">
    <div class="hero-overlay"></div>
    <div class="hero-content z-1">
      <h1 class="display-3 fw-bold mb-3 hero-title">Find Your Next Adventure</h1>
      <p class="lead mb-4 fs-4 hero-subtitle">Discover unique homes, breathtaking locations, and extraordinary
        experiences around the globe.</p>
      <a href="/listings" class="btn btn-lg btn-danger px-5 py-3 rounded-pill shadow-lg hero-cta">
        <i class="fa-solid fa-earth-americas me-2"></i> Explore Now
      </a>
    </div>
  </div>

  <!-- Features Section -->
  <div class="container my-5 features-section">
    <div class="text-center mb-5">
      <h2 class="fw-bold fs-1">Why WanderLust?</h2>
      <p class="text-muted fs-5">Everything you need for the perfect getaway.</p>
    </div>
    <div class="row g-4 text-center">
      <!-- Feature 1 -->
      <div class="col-md-4">
        <div class="feature-card p-4 rounded-4 shadow-sm border h-100 bg-white">
          <div class="icon-wrapper mb-3 text-danger fs-1">
            <i class="fa-solid fa-house-chimney-window"></i>
          </div>
          <h4 class="fw-semibold">Unique Stays</h4>
          <p class="text-muted">From cozy cabins in the woods to luxury penthouses in the city.</p>
        </div>
      </div>
      <!-- Feature 2 -->
      <div class="col-md-4">
        <div class="feature-card p-4 rounded-4 shadow-sm border h-100 bg-white">
          <div class="icon-wrapper mb-3 text-danger fs-1">
            <i class="fa-solid fa-shield-halved"></i>
          </div>
          <h4 class="fw-semibold">Secure Booking</h4>
          <p class="text-muted">Your seamless and secure reservation is our top priority.</p>
        </div>
      </div>
      <!-- Feature 3 -->
      <div class="col-md-4">
        <div class="feature-card p-4 rounded-4 shadow-sm border h-100 bg-white">
          <div class="icon-wrapper mb-3 text-danger fs-1">
            <i class="fa-solid fa-headset"></i>
          </div>
          <h4 class="fw-semibold">24/7 Support</h4>
          <p class="text-muted">We're here to help, anytime, anywhere around the world.</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Categories Teaser -->
  <div class="container mb-5 categories-teaser bg-light p-5 rounded-5 shadow-sm text-center">
    <h3 class="fw-bold mb-4">Popular Categories</h3>
    <div class="d-flex flex-wrap justify-content-center gap-3">
      <a href="/listings?category=Beachfront" class="btn btn-outline-dark rounded-pill px-4"><i
          class="fa-solid fa-umbrella-beach me-2"></i>Beachfront</a>
      <a href="/listings?category=Mountains" class="btn btn-outline-dark rounded-pill px-4"><i
          class="fa-solid fa-mountain me-2"></i>Mountains</a>
      <a href="/listings?category=Iconic Cities" class="btn btn-outline-dark rounded-pill px-4"><i
          class="fa-solid fa-city me-2"></i>Iconic Cities</a>
      <a href="/listings?category=Camping" class="btn btn-outline-dark rounded-pill px-4"><i
          class="fa-solid fa-campground me-2"></i>Camping</a>
    </div>
  </div>